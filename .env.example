# Copy this to `.env.local` for local dev. Never commit `.env.local`.

# --- Database (Neon PostgreSQL serverless) ---
# Used by both the runtime Kysely client and dbmate migrations.
# On Neon, use the *direct* (non-pooled) connection string so DDL runs cleanly.
# Point runtime traffic at the pooled URL on Vercel via env-var override.
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# --- NextAuth v5 / Auth.js ---
# Generate with: `openssl rand -base64 32`
AUTH_SECRET=""
# Optional in dev (auto-detected from request); required in production.
AUTH_URL="http://localhost:3000"

# --- Google OAuth provider ---
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
